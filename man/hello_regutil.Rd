\name{hello_regutil}
\alias{hello_regutil}
\title{Say Hello from regutil}
\usage{
hello_regutil(name = "world")
}
\arguments{
\item{name}{Name to include in the greeting. Defaults to \code{"world"}.}
}
\value{
A length-1 character vector.
}
\description{
Simple starter function to confirm the package loads and exports correctly.
}
\examples{
hello_regutil()
hello_regutil("team")
}

